# Profundiza UQ backend configuration. Copy to .env and adjust. Never commit secrets.
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/profundiza_uq?sslmode=disable

# COOKIE_SECURE controls the Secure flag on the session cookie.
# Must be true in staging/production (HTTPS only). Set false only for local dev
# over plain HTTP. The server refuses to start with false in non-development
# environments.
COOKIE_SECURE=false

SESSION_TTL=12h
OTP_TTL=10m

# ALLOWED_EMAIL_DOMAINS is a comma-separated list of institutional email domains
# that are permitted to log in (e.g. uniquindio.edu.co). Restricts who can
# authenticate; any email outside this list is silently rejected.
# Leave unset in development to allow any domain. The server refuses to start
# with an empty list in non-development environments.
ALLOWED_EMAIL_DOMAINS=uniquindio.edu.co

SMTP_ADDR=localhost:1025
MAIL_FROM=no-reply@profundiza-uq.edu.co
REPORTS_OUTPUT_DIR=./reports-output
